# Copy this file to .env and fill in real values.

# Local dev: SQLite file. Production (Vercel): PostgreSQL connection string (e.g. from Neon).
DATABASE_URL="file:./dev.db"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# MoMo payment gateway (sandbox test credentials — replace with your merchant
# credentials from https://business.momo.vn before going live)
MOMO_PARTNER_CODE=""
MOMO_ACCESS_KEY=""
MOMO_SECRET_KEY=""
MOMO_ENDPOINT="https://test-payment.momo.vn/v2/gateway/api/create"

NEXT_PUBLIC_BASE_URL="http://localhost:3000"
